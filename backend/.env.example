# --- Base de datos (Supabase PostgreSQL) ---
# Connection pooler de Supabase (PgBouncer, puerto 6543). La usa la app en runtime.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Session Pooler de Supabase (puerto 5432, compatible IPv4). Solo la usa Prisma Migrate.
# Nota: la conexión directa db.<project-ref>.supabase.co solo tiene IPv6, por eso usamos el pooler también aquí.
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# --- Supabase Auth ---
SUPABASE_URL="https://qirhpcldhldazzdivtdk.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"

# --- CORS ---
FRONTEND_URL="http://localhost:5173"

# --- Servidor ---
NODE_ENV="development"
PORT=3000
